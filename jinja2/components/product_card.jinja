{% macro product_card(product) -%}
<div class="product-card group">
    {% set image = product.images.all()|list|first %}
    {# Discount badge #}
    {% if product.discounted_price %}
        {% set discount_pct = (((product.price - product.discounted_price) / product.price) * 100)|int %}
        <span class="discount-badge">-{{ discount_pct }}%</span>
    {% endif %}
    <a href="{{ url('catalog:product_detail', slug=product.slug) }}" class="block overflow-hidden bg-gray-50">
        {% if image %}
            <img src="{{ image.image.url }}" alt="{{ product.name }}" class="product-thumb transition duration-300 group-hover:scale-105">
        {% else %}
            <div class="product-thumb flex items-center justify-center text-sm text-gray-400 bg-gray-100">
                <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
            </div>
        {% endif %}
    </a>
    <div class="product-card-body">
        <a href="{{ url('catalog:product_detail', slug=product.slug) }}" class="product-title hover:text-pink-500 transition">{{ product.name }}</a>
        <div class="flex items-baseline gap-2 mt-1">
            {% if product.discounted_price %}
                <span class="price-old">{{ product.price|money }}</span>
            {% endif %}
            <span class="price-current">{{ product.current_price|money }}</span>
        </div>
        <form action="{{ url('cart:add', product_id=product.id) }}" method="post" class="mt-auto pt-2">
            {{ csrf_input }}
            <button type="submit" class="add-to-cart-btn w-full">
                <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121 0 2.09-.773 2.342-1.868l1.563-6.834A1.125 1.125 0 0020.28 3.75H5.25"/></svg>
                Shto në shportë
            </button>
        </form>
    </div>
</div>
{%- endmacro %}

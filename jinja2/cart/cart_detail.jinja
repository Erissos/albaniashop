{% extends 'layouts/base.jinja' %}

{% block title %}Shporta | Albaniashop{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[1fr_360px]">
    {# ── Cart Items ── #}
    <div class="panel">
        <h1 class="text-xl font-extrabold text-gray-900 mb-6">Shporta juaj</h1>
        <div class="space-y-4">
            {% for item in cart_items %}
                <div class="border border-gray-100 rounded-lg p-4 flex flex-wrap items-start gap-4">
                    <div class="flex-1">
                        <p class="font-semibold text-gray-800">{{ item.product.name }}</p>
                        <p class="text-sm text-gray-500 mt-0.5">{{ item.variation.title if item.variation and item.variation.title else item.variation.value if item.variation else 'Standard' }}</p>
                        <p class="text-sm text-gray-400 mt-1">{{ item.unit_price|money }} / copë</p>
                    </div>
                    <p class="text-lg font-bold text-gray-900">{{ item.subtotal|money }}</p>
                    <div class="w-full flex items-center gap-2 mt-2">
                        <form action="{{ url('cart:update_quantity', item_id=item.id) }}" method="post">
                            {{ csrf_input }}
                            <input type="hidden" name="action" value="decrease">
                            <button type="submit" class="btn-outline btn-sm">−</button>
                        </form>
                        <span class="px-3 py-1 text-sm font-semibold text-gray-700 border border-gray-200 rounded">{{ item.quantity }}</span>
                        <form action="{{ url('cart:update_quantity', item_id=item.id) }}" method="post">
                            {{ csrf_input }}
                            <input type="hidden" name="action" value="increase">
                            <button type="submit" class="btn-outline btn-sm">+</button>
                        </form>
                        <form action="{{ url('cart:remove', item_id=item.id) }}" method="post" class="ml-auto">
                            {{ csrf_input }}
                            <button type="submit" class="text-sm text-gray-400 hover:text-red-500 transition">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="text-center py-12 text-gray-400">
                    <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121 0 2.09-.773 2.342-1.868l1.563-6.834A1.125 1.125 0 0020.28 3.75H5.25"/></svg>
                    <p class="text-lg font-semibold">Shporta juaj është bosh</p>
                    <a href="{{ url('core:all_products') }}" class="btn-pink mt-4 inline-flex">Shfleto produktet</a>
                </div>
            {% endfor %}
        </div>
    </div>

    {# ── Summary ── #}
    <aside class="panel h-fit sticky top-24">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Përmbledhja</h2>
        <div class="space-y-3 text-sm text-gray-600">
            <div class="flex justify-between"><span>Artikuj</span><span class="text-gray-800 font-semibold">{{ cart_items|length }}</span></div>
            <div class="flex justify-between"><span>Nëntotali</span><span class="text-gray-800 font-semibold">{{ cart.total|money }}</span></div>
            <div class="flex justify-between"><span>Transporti</span><span class="text-green-600 font-semibold">Falas</span></div>
            <div class="flex justify-between"><span>Paketimi</span><span class="text-gray-800">Diskret</span></div>
        </div>
        <div class="border-t border-gray-100 mt-4 pt-4 flex justify-between text-base font-bold text-gray-900">
            <span>Totali</span>
            <span>{{ cart.total|money }}</span>
        </div>
        <a href="{{ url('orders:checkout') }}" class="btn-pink btn-lg w-full mt-4 text-center">Vazhdo me porosinë</a>
        <p class="mt-3 text-xs text-gray-400 text-center">Pagesa e sigurt & paketim diskret</p>
    </aside>
</div>
{% endblock %}

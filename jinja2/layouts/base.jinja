{% set current_language = request.LANGUAGE_CODE if request and request.LANGUAGE_CODE else 'sq' %}
<!doctype html>
<html lang="{{ current_language }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Albaniashop - Dyqani juaj online i preferuar">
    <title>{% block title %}Albaniashop{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        pink: {
                            50: '#fdf2f8', 100: '#fce7f3', 200: '#fbcfe8', 300: '#f9a8d4',
                            400: '#f472b6', 500: '#ec4899', 600: '#db2777', 700: '#be185d',
                        }
                    },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="{{ static('css/design-system.css') }}">
    {% block extra_head %}{% endblock %}
</head>
<body class="min-h-screen bg-white font-sans text-gray-900">

    {# ── Top Announcement Bar ── #}
    <div class="bg-gray-900 text-white text-xs">
        <div class="shell flex items-center justify-between py-2">
            <div class="flex items-center gap-2">
                <span>Dërgesa <strong class="text-pink-400">FALAS</strong> për Porosi mbi 2,000 Lekë</span>
                <span class="text-gray-500 hidden sm:inline">|</span>
                <span class="hidden sm:inline">Gift Card nga Albaniashop</span>
            </div>
            <div class="flex items-center gap-4">
                <span class="font-semibold">ALL</span>
                <a href="{{ url('accounts:wishlist') }}" class="hidden sm:inline hover:text-pink-300 transition">Të preferuarat</a>
                <a href="{{ url('pages:about') }}" class="hidden sm:inline hover:text-pink-300 transition">Dyqani ynë</a>
                <div class="flex items-center gap-2 ml-2">
                    <svg class="w-3.5 h-3.5 text-gray-400 hover:text-white cursor-pointer" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    <svg class="w-3.5 h-3.5 text-gray-400 hover:text-white cursor-pointer" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </div>
            </div>
        </div>
    </div>

    {# ── Main Header ── #}
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
        <div class="shell flex items-center gap-6 py-3">
            {# Logo #}
            <a href="{{ url('core:home') }}" class="flex-shrink-0">
                <span class="text-2xl font-extrabold tracking-tight text-pink-500">albaniashop</span>
            </a>

            {# Search Bar #}
            <form action="{{ url('core:all_products') }}" method="get" class="hidden md:flex flex-1 max-w-2xl">
                <div class="flex w-full border border-gray-200 rounded-lg overflow-hidden focus-within:border-pink-400 focus-within:ring-2 focus-within:ring-pink-100 transition">
                    <input type="search" name="q" value="{{ request.GET.get('q', '') if request else '' }}" placeholder="Kërko mbi 3000 produkte..." class="flex-1 px-4 py-2.5 text-sm outline-none placeholder:text-gray-400">
                    <button type="submit" class="px-4 bg-white border-l border-gray-200 text-gray-400 hover:text-pink-500 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                    </button>
                </div>
            </form>

            {# Right: Account & Cart #}
            <div class="ml-auto flex items-center gap-4">
                {% if request.user.is_authenticated %}
                    <a href="{{ url('accounts:dashboard') }}" class="hidden sm:flex items-center gap-2 text-sm text-gray-600 hover:text-pink-500 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                        <div class="text-left leading-tight">
                            <div class="text-xs text-gray-400">Llogaria ime</div>
                            <div class="text-sm font-semibold text-gray-700">{{ request.user.first_name or 'Profili' }}</div>
                        </div>
                    </a>
                {% else %}
                    <a href="{{ url('accounts:login') }}" class="hidden sm:flex items-center gap-2 text-sm text-gray-600 hover:text-pink-500 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                        <div class="text-left leading-tight">
                            <div class="text-xs text-gray-400">Hyr / Regjistrohu</div>
                            <div class="text-sm font-semibold text-gray-700">Llogaria ime</div>
                        </div>
                    </a>
                {% endif %}

                <a href="{{ url('cart:detail') }}" class="flex items-center gap-2 text-sm text-gray-600 hover:text-pink-500 transition">
                    <div class="relative">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121 0 2.09-.773 2.342-1.868l1.563-6.834A1.125 1.125 0 0020.28 3.75H5.25m2.25 10.5V6h13.5"/></svg>
                        {% if header_cart_total_items %}
                            <span class="absolute -top-1.5 -right-1.5 bg-pink-500 text-white rounded-full w-4 h-4 text-[10px] font-bold flex items-center justify-center">{{ header_cart_total_items }}</span>
                        {% endif %}
                    </div>
                    <div class="text-left leading-tight hidden sm:block">
                        <div class="text-xs text-gray-400">Shporta</div>
                        <div class="text-sm font-bold text-gray-800">{{ header_cart_total_items or 0 }} LEK</div>
                    </div>
                </a>
            </div>

            {# Mobile Menu Toggle #}
            <button data-mobile-toggle class="lg:hidden text-gray-600 hover:text-pink-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
            </button>
        </div>

        {# ── Navigation ── #}
        <nav class="border-t border-gray-100 bg-white">
            <div class="shell hidden lg:flex items-center gap-1 py-0 text-sm">
                <a href="{{ url('core:all_products') }}?sort=newest" class="px-3 py-3 font-semibold text-pink-500 hover:bg-pink-50 transition rounded-t-lg">Të Reja</a>
                <a href="{{ url('core:all_products') }}?on_sale=1" class="px-3 py-3 font-semibold text-pink-500 hover:bg-pink-50 transition rounded-t-lg">Oferta</a>
                {% for category in header_categories %}
                    <a href="{{ url('catalog:product_list_by_category', category_slug=category.slug) }}" class="px-3 py-3 text-gray-700 hover:text-pink-500 hover:bg-pink-50 transition rounded-t-lg">{{ category.name }}</a>
                {% endfor %}
            </div>
        </nav>

        {# ── Mobile Nav Panel ── #}
        <div data-mobile-panel class="hidden lg:hidden border-t border-gray-100 bg-white p-4">
            <form action="{{ url('core:all_products') }}" method="get" class="mb-4">
                <input type="search" name="q" placeholder="Kërko..." class="form-input">
            </form>
            <div class="space-y-1">
                <a href="{{ url('core:all_products') }}" class="block px-3 py-2 rounded-lg text-sm font-semibold text-pink-500 hover:bg-pink-50">Të Reja</a>
                <a href="{{ url('core:all_products') }}?on_sale=1" class="block px-3 py-2 rounded-lg text-sm font-semibold text-pink-500 hover:bg-pink-50">Oferta</a>
                {% for category in header_categories %}
                    <a href="{{ url('catalog:product_list_by_category', category_slug=category.slug) }}" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-pink-50 hover:text-pink-500">{{ category.name }}</a>
                {% endfor %}
            </div>
        </div>
    </header>

    {# ── Flash Messages ── #}
    {% if messages %}
        <div class="shell mt-4 space-y-2">
            {% for message in messages %}
                <div class="border border-pink-200 bg-pink-50 rounded-lg px-4 py-3 text-sm text-pink-700">{{ message }}</div>
            {% endfor %}
        </div>
    {% endif %}

    {# ── Main Content ── #}
    <main class="{% block main_class %}shell py-6 md:py-8{% endblock %}">
        {% block content %}{% endblock %}
    </main>

    {# ── Footer ── #}
    <footer class="bg-gray-900 text-gray-300 mt-12">
        <div class="shell grid gap-8 py-12 md:grid-cols-4">
            <div>
                <span class="text-2xl font-extrabold text-white">albaniashop</span>
                <p class="mt-3 text-sm leading-6 text-gray-400">Dyqani juaj online i preferuar me produkte cilësore, transport falas dhe paketim diskret.</p>
                <div class="mt-4 flex gap-3">
                    <span class="w-8 h-8 bg-gray-800 rounded-full flex items-center justify-center hover:bg-pink-500 transition cursor-pointer">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </span>
                    <span class="w-8 h-8 bg-gray-800 rounded-full flex items-center justify-center hover:bg-pink-500 transition cursor-pointer">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </span>
                </div>
            </div>
            <div>
                <p class="text-sm font-bold text-white uppercase tracking-wider mb-4">Zbulo</p>
                <div class="space-y-2 text-sm">
                    <a href="{{ url('core:all_products') }}" class="block hover:text-pink-400 transition">Të gjitha produktet</a>
                    <a href="{{ url('core:all_products') }}?on_sale=1" class="block hover:text-pink-400 transition">Oferta</a>
                    <a href="{{ url('pages:about') }}" class="block hover:text-pink-400 transition">Rreth nesh</a>
                    <a href="{{ url('pages:contact') }}" class="block hover:text-pink-400 transition">Kontakt</a>
                </div>
            </div>
            <div>
                <p class="text-sm font-bold text-white uppercase tracking-wider mb-4">Ndihma</p>
                <div class="space-y-2 text-sm">
                    <a href="{{ url('accounts:order_history') }}" class="block hover:text-pink-400 transition">Historiku i porosive</a>
                    <a href="{{ url('pages:cargo_tracking') }}" class="block hover:text-pink-400 transition">Gjurmimi i dërgesës</a>
                    <a href="{{ url('pages:contracts') }}" class="block hover:text-pink-400 transition">Kushtet e përdorimit</a>
                </div>
            </div>
            <div>
                <p class="text-sm font-bold text-white uppercase tracking-wider mb-4">Besueshmëria</p>
                <div class="space-y-2 text-sm text-gray-400">
                    <p>Produkte Europiane të certifikuara</p>
                    <p>Paketim anonim & diskret</p>
                    <p>Transport falas Shqipëri & Kosovë</p>
                    <p>Pagesa e sigurt me kartë/cash</p>
                </div>
            </div>
        </div>
        <div class="border-t border-gray-800">
            <div class="shell py-4 text-center text-xs text-gray-500">&copy; {{ 2026 }} Albaniashop. Të gjitha të drejtat e rezervuara.</div>
        </div>
    </footer>

    <script src="{{ static('js/main.js') }}"></script>
    {% block extra_js %}{% endblock %}
</body>
</html>

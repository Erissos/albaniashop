{% extends 'layouts/base.jinja' %}

{% block title %}Porosia u konfirmua | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-2xl">
    <div class="panel text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h1 class="text-2xl font-extrabold text-gray-900">Faleminderit për porosinë!</h1>
        <p class="mt-3 text-gray-500">Porosia juaj <strong class="text-gray-800">{{ order.order_number }}</strong> u krijua me sukses.</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2 text-left text-sm">
            <div class="bg-gray-50 rounded-lg p-4"><span class="text-gray-400 text-xs font-semibold uppercase">Statusi</span><p class="mt-1 font-semibold text-gray-800">{{ order.status }}</p></div>
            <div class="bg-gray-50 rounded-lg p-4"><span class="text-gray-400 text-xs font-semibold uppercase">Totali</span><p class="mt-1 font-semibold text-gray-800">{{ order.total_amount|money(order.currency) }}</p></div>
        </div>
        <div class="mt-6 flex justify-center gap-3">
            <a href="{{ url('accounts:order_history') }}" class="btn-outline">Shiko porositë</a>
            <a href="{{ url('core:all_products') }}" class="btn-pink">Vazhdo blerjet</a>
        </div>
    </div>
</section>
{% endblock %}

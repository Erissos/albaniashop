{% extends 'layouts/base.jinja' %}

{% block title %}Kontakt | Albaniashop{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900">Na kontaktoni</h1>
        <p class="mt-3 text-gray-500 text-sm leading-6">Përdorni këtë formë për pyetje rreth produkteve, mbështetje porosish, kërkesa bashkëpunimi dhe ndihmë të personalizuar.</p>
        <div class="mt-6 space-y-3 text-sm text-gray-600">
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg> info@albaniashop.al</div>
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg> +355 69 123 4567</div>
        </div>
    </div>
    <div class="panel">
        <form method="post" class="grid gap-4 md:grid-cols-2">
            {{ csrf_input }}
            {% for field in form %}
                <div class="{{ 'md:col-span-2' if field.name == 'message' else '' }}">
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">{{ field.label }}</label>
                    {{ field }}
                    {% if field.errors %}<div class="mt-1 text-sm text-red-600">{{ field.errors }}</div>{% endif %}
                </div>
            {% endfor %}
            <div class="md:col-span-2"><button type="submit" class="btn-pink btn-lg w-full">Dërgo mesazhin</button></div>
        </form>
    </div>
</div>
{% endblock %}

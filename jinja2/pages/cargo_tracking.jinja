{% extends 'layouts/base.jinja' %}

{% block title %}Gjurmo dërgesën | Albaniashop{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[400px_1fr]">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900">Gjurmo dërgesën</h1>
        <form method="get" class="mt-5 space-y-4">
            <div>
                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Kodi i gjurmimit</label>
                <input type="text" name="code" value="{{ code }}" class="form-input" placeholder="Shkruani kodin e gjurmimit">
            </div>
            <button type="submit" class="btn-pink btn-lg w-full">Gjurmo</button>
        </form>
    </div>
    <div class="panel">
        {% if tracking %}
            <h2 class="text-lg font-bold text-gray-900">{{ tracking.tracking_code }}</h2>
            <div class="mt-4 grid gap-4 md:grid-cols-3">
                <div class="bg-gray-50 rounded-lg p-3">
                    <span class="text-xs text-gray-400 font-semibold">Transportuesi</span>
                    <p class="mt-0.5 text-gray-800 font-medium">{{ tracking.carrier_name }}</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                    <span class="text-xs text-gray-400 font-semibold">Statusi</span>
                    <p class="mt-0.5 text-gray-800 font-medium">{{ tracking.current_status or 'Në përpunim' }}</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                    <span class="text-xs text-gray-400 font-semibold">Porosi</span>
                    <p class="mt-0.5 text-gray-800 font-medium">{{ tracking.order.order_number }}</p>
                </div>
            </div>
        {% else %}
            <div class="text-center py-10">
                <svg class="w-10 h-10 text-gray-300 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
                <p class="mt-3 text-gray-400 text-sm">Shkruani kodin për të parë statusin e dërgesës.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

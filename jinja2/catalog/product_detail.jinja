{% extends 'layouts/base.jinja' %}

{% block title %}{{ product.name }} | Albaniashop{% endblock %}

{% block content %}
{% set images = product.images.all()|list %}
{% set primary_image = images|first %}
{% set variations = product.variations.all()|list %}
{% set attributes = product.attribute_values.all()|list %}

{# ── Breadcrumb ── #}
<nav class="text-sm text-gray-500 mb-6">
    <a href="{{ url('core:home') }}" class="hover:text-pink-500">Kryefaqja</a>
    <span class="mx-1">/</span>
    <a href="{{ url('catalog:product_list_by_category', category_slug=product.category.slug) }}" class="hover:text-pink-500">{{ product.category.name }}</a>
    <span class="mx-1">/</span>
    <span class="text-gray-800">{{ product.name }}</span>
</nav>

<div class="grid gap-8 lg:grid-cols-2">
    {# ── Product Images ── #}
    <div class="space-y-3">
        <div class="panel p-2 overflow-hidden">
            {% if primary_image %}
                <img data-gallery-main src="{{ primary_image.image.url }}" alt="{{ product.name }}" class="w-full aspect-square object-cover rounded-lg cursor-zoom-in" data-gallery-open>
            {% else %}
                <div class="w-full aspect-square flex items-center justify-center bg-gray-50 rounded-lg text-gray-400">
                    <svg class="w-24 h-24" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5"/></svg>
                </div>
            {% endif %}
        </div>
        {% if images|length > 1 %}
            <div class="grid grid-cols-4 gap-2">
                {% for image in images[:4] %}
                    <img data-gallery-target="{{ image.image.url }}" src="{{ image.image.url }}" alt="{{ image.alt_text or product.name }}" class="aspect-square object-cover rounded-lg border-2 border-transparent hover:border-pink-400 cursor-pointer transition">
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ── Product Info ── #}
    <div class="space-y-5">
        <div>
            <p class="text-sm text-pink-500 font-semibold">{{ product.category.name }}</p>
            <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 mt-1">{{ product.name }}</h1>
            <p class="text-gray-500 mt-2 leading-relaxed">{{ product.short_description }}</p>
        </div>

        {# Price Block #}
        <div class="flex items-end gap-3 border-b border-gray-100 pb-4">
            {% if product.discounted_price %}
                {% set discount_pct = (((product.price - product.discounted_price) / product.price) * 100)|int %}
                <span class="text-sm line-through text-gray-400">{{ product.price|money }}</span>
                <span class="text-3xl font-extrabold text-pink-600">{{ product.current_price|money }}</span>
                <span class="bg-pink-100 text-pink-700 text-xs font-bold px-2 py-1 rounded">-{{ discount_pct }}%</span>
            {% else %}
                <span class="text-3xl font-extrabold text-gray-900">{{ product.current_price|money }}</span>
            {% endif %}
        </div>

        {# Stock & Info #}
        <div class="flex flex-wrap gap-3 text-sm">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full {{ 'bg-green-50 text-green-700' if product.stock_quantity > 0 else 'bg-red-50 text-red-600' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="{{ 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' if product.stock_quantity > 0 else 'M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z' }}"/></svg>
                {{ 'Në stok' if product.stock_quantity > 0 else 'Nuk ka stok' }}
            </span>
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-gray-50 text-gray-600">
                SKU: {{ product.sku }}
            </span>
            {% if product.rating_average > 0 %}
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-yellow-50 text-yellow-700">
                    ★ {{ product.rating_average }}
                </span>
            {% endif %}
        </div>

        {# Add to Cart Form #}
        <div class="panel">
            <form action="{{ url('cart:add', product_id=product.id) }}" method="post" class="space-y-4">
                {{ csrf_input }}
                {% if variations %}
                    <div>
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Varianti</label>
                        <select name="variation_id" class="form-input">
                            <option value="">Zgjidhni një opsion</option>
                            {% for variation in variations %}
                                <option value="{{ variation.id }}">{{ variation.title or variation.value }}{% if variation.price_delta %} (+{{ variation.price_delta|money }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% endif %}
                <div class="flex gap-3">
                    <button type="submit" class="btn-pink btn-lg flex-1">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121 0 2.09-.773 2.342-1.868l1.563-6.834A1.125 1.125 0 0020.28 3.75H5.25"/></svg>
                        Shto në shportë
                    </button>
                    {% if request.user.is_authenticated %}
                        <form action="{{ url('accounts:toggle_wishlist', product_id=product.id) }}" method="post">
                            {{ csrf_input }}
                            <button type="submit" class="btn-outline btn-lg" title="Shto në listën e deshirave">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                            </button>
                        </form>
                    {% endif %}
                </div>
            </form>
            <div class="mt-4 flex flex-wrap gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-pink-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25"/></svg>
                    Transport falas
                </span>
                <span class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-pink-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25"/></svg>
                    Paketim diskret
                </span>
                <span class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-pink-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622"/></svg>
                    Pagesa e sigurt
                </span>
            </div>
        </div>

        {# Description #}
        <div class="panel">
            <h3 class="text-sm font-bold text-gray-800 mb-3">Përshkrimi</h3>
            <div class="text-sm text-gray-600 leading-7">{{ product.description }}</div>
            {% if attributes %}
                <div class="mt-4 grid gap-2 sm:grid-cols-2">
                    {% for item in attributes %}
                        <div class="bg-gray-50 rounded-lg px-4 py-3 text-sm">
                            <p class="text-xs text-gray-400 font-semibold">{{ item.attribute.name }}</p>
                            <p class="text-gray-800 mt-0.5">{{ item.display_value or item.value }}</p>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# ── Reviews ── #}
<section class="mt-10">
    <div class="panel">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Vlerësimet e klientëve</h2>
        <div class="space-y-4">
            {% for review in approved_reviews %}
                <div class="border border-gray-100 rounded-lg p-4">
                    <div class="flex items-center justify-between">
                        <p class="font-semibold text-gray-800">{{ review.title }}</p>
                        <span class="text-sm text-yellow-500 font-bold">★ {{ review.rating }}/5</span>
                    </div>
                    <p class="mt-2 text-sm text-gray-600 leading-6">{{ review.comment }}</p>
                </div>
            {% else %}
                <p class="text-sm text-gray-400 text-center py-6">Nuk ka vlerësime ende.</p>
            {% endfor %}
        </div>
    </div>
</section>

{# ── Related Products ── #}
{% if related_products %}
<section class="mt-10">
    <div class="section-header">
        <h2 class="section-title">Produkte të ngjashme</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        {% for item in related_products %}
            {{ product_card(item) }}
        {% endfor %}
    </div>
</section>
{% endif %}

{# ── Image Modal ── #}
<div data-gallery-modal class="hidden fixed inset-0 z-[100] bg-black/70 items-center justify-center p-4">
    <div class="relative max-w-3xl w-full">
        <button data-gallery-close class="absolute -top-10 right-0 text-white text-3xl">&times;</button>
        <img data-gallery-modal-image src="" alt="Zoom" class="w-full rounded-xl">
    </div>
</div>
{% endblock %}

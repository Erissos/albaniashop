{% extends 'layouts/base.jinja' %}
{% from 'components/product_card.jinja' import product_card with context %}

{% block title %}{{ selected_category.name if selected_category else 'Të gjitha produktet' }} | Albaniashop{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[280px_1fr]">
    {# ── Sidebar Filters ── #}
    <aside class="space-y-4">
        <div class="panel">
            <h2 class="text-lg font-bold text-gray-900 mb-1">{{ selected_category.name if selected_category else 'Të gjitha produktet' }}</h2>
            <p class="text-sm text-gray-500 mb-4">{{ product_count }} produkte</p>

            <form method="get" class="space-y-4">
                <div>
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Kërko</label>
                    <input type="search" name="q" value="{{ query }}" class="form-input" placeholder="Emri i produktit...">
                </div>
                <div>
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Brendi</label>
                    <select name="brand" class="form-input">
                        <option value="">Të gjitha</option>
                        {% for brand in brands %}
                            <option value="{{ brand.slug }}" {{ 'selected' if selected_brand == brand.slug else '' }}>{{ brand.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Çmimi min</label>
                        <input type="number" name="min_price" value="{{ min_price }}" class="form-input" placeholder="{{ price_range.min_price or 0 }}">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Çmimi max</label>
                        <input type="number" name="max_price" value="{{ max_price }}" class="form-input" placeholder="{{ price_range.max_price or 0 }}">
                    </div>
                </div>
                <div>
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">Rendit</label>
                    <select name="sort" class="form-input">
                        <option value="">Të preferuara</option>
                        <option value="price_asc" {{ 'selected' if sort == 'price_asc' else '' }}>Çmimi: Ulët → Lartë</option>
                        <option value="price_desc" {{ 'selected' if sort == 'price_desc' else '' }}>Çmimi: Lartë → Ulët</option>
                        <option value="name_asc" {{ 'selected' if sort == 'name_asc' else '' }}>Emri: A-Z</option>
                    </select>
                </div>
                <div class="space-y-2 border border-gray-100 rounded-lg p-3">
                    <label class="flex items-center justify-between text-sm text-gray-700">
                        <span>Në stok</span>
                        <input type="checkbox" name="in_stock" value="1" {{ 'checked' if in_stock else '' }} class="accent-pink-500">
                    </label>
                    <label class="flex items-center justify-between text-sm text-gray-700">
                        <span>Me ofertë</span>
                        <input type="checkbox" name="on_sale" value="1" {{ 'checked' if on_sale else '' }} class="accent-pink-500">
                    </label>
                </div>
                <button type="submit" class="btn-pink w-full">Filtro</button>
            </form>
        </div>

        <div class="panel">
            <h3 class="text-sm font-bold text-gray-800 mb-3">Kategoritë</h3>
            <div class="space-y-1">
                {% for category in filter_categories %}
                    <a href="{{ url('catalog:product_list_by_category', category_slug=category.slug) }}" class="block px-3 py-2 text-sm rounded-lg text-gray-600 hover:bg-pink-50 hover:text-pink-600 transition">{{ category.name }}</a>
                {% endfor %}
            </div>
        </div>
    </aside>

    {# ── Product Grid ── #}
    <div>
        {% if selected_category and selected_category.description %}
            <div class="panel mb-4">
                <p class="text-sm text-gray-600">{{ selected_category.description }}</p>
            </div>
        {% endif %}

        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {% for product in products %}
                {{ product_card(product) }}
            {% else %}
                <div class="col-span-full panel text-center text-gray-500 py-12">
                    <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                    <p class="text-lg font-semibold">Asnjë produkt nuk u gjet</p>
                    <p class="text-sm mt-1">Provoni të ndryshoni filtrat tuaj</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

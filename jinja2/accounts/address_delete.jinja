{% extends 'layouts/base.jinja' %}

{% block title %}Fshij adresën | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-md">
    <div class="panel text-center">
        <div class="mx-auto w-14 h-14 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
        </div>
        <h1 class="text-xl font-bold text-gray-900 mt-4">Fshij adresën</h1>
        <p class="text-sm text-gray-500 mt-2">Jeni i sigurt që doni të fshini adresën <strong>{{ address.title }}</strong> për {{ address.full_name }}?</p>
        <form method="post" class="mt-6 flex gap-3 justify-center">
            {{ csrf_input }}
            <button type="submit" class="btn-pink bg-red-500 hover:bg-red-600">Po, fshije</button>
            <a href="{{ url('accounts:address_list') }}" class="btn-outline">Anulo</a>
        </form>
    </div>
</section>
{% endblock %}

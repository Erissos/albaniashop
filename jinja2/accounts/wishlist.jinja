{% extends 'layouts/base.jinja' %}

{% block title %}Të preferuarat | Albaniashop{% endblock %}

{% block content %}
<h1 class="text-2xl font-extrabold text-gray-900 mb-6">Të preferuarat</h1>
{% if items %}
<div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
    {% for item in items %}
    {% set p = item.product %}
    <div class="panel relative group">
        <form method="post" action="{{ url('accounts:toggle_wishlist', product_id=p.id) }}" class="absolute top-3 right-3 z-10">
            {{ csrf_input }}
            <button type="submit" class="w-8 h-8 rounded-full bg-white shadow flex items-center justify-center text-red-500 hover:bg-red-50 transition" title="Hiq">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </form>
        <a href="{{ url('catalog:product_detail', slug=p.slug) }}">
            {% if p.primary_image %}
            <img src="{{ p.primary_image.url }}" alt="{{ p.name }}" class="w-full aspect-square object-cover rounded-lg">
            {% else %}
            <div class="w-full aspect-square bg-gray-100 rounded-lg flex items-center justify-center text-gray-300">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5"/></svg>
            </div>
            {% endif %}
            <h3 class="mt-3 text-sm font-semibold text-gray-800 line-clamp-2">{{ p.name }}</h3>
            <p class="mt-1 text-pink-500 font-bold">{{ p.current_price|money }}</p>
        </a>
        <form method="post" action="{{ url('cart:add', product_id=p.id) }}" class="mt-3">
            {{ csrf_input }}
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn-pink btn-sm w-full">Shto në shportë</button>
        </form>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="panel text-center py-12">
    <svg class="w-12 h-12 text-gray-300 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
    <p class="mt-4 text-gray-500">Lista e të preferuarave është bosh.</p>
    <a href="{{ url('catalog:product_list') }}" class="btn-pink mt-4 inline-block">Shfleto produktet</a>
</div>
{% endif %}
{% endblock %}

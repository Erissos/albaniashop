{% extends 'layouts/base.jinja' %}

{% block title %}Paneli | Albaniashop{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[280px_1fr]">
    {# Sidebar #}
    <aside class="panel h-fit">
        <h1 class="text-lg font-extrabold text-gray-900">{{ request.user.get_full_name() or request.user.username }}</h1>
        <p class="text-sm text-gray-500 mt-1">{{ request.user.email }}</p>
        <nav class="mt-5 space-y-1">
            <a href="{{ url('accounts:edit_profile') }}" class="flex items-center gap-2 px-3 py-2 text-sm rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
                Ndrysho profilin
            </a>
            <a href="{{ url('accounts:address_list') }}" class="flex items-center gap-2 px-3 py-2 text-sm rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                Adresat
            </a>
            <a href="{{ url('accounts:order_history') }}" class="flex items-center gap-2 px-3 py-2 text-sm rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/></svg>
                Porositë
            </a>
            <a href="{{ url('accounts:wishlist') }}" class="flex items-center gap-2 px-3 py-2 text-sm rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                Të preferuarat
            </a>
        </nav>
    </aside>

    {# Main #}
    <div class="space-y-5">
        <div class="panel">
            <h2 class="text-base font-bold text-gray-800 mb-3">Informacioni i profilit</h2>
            <div class="grid gap-4 md:grid-cols-2 text-sm">
                <div class="bg-gray-50 rounded-lg p-3"><span class="text-xs text-gray-400 font-semibold">Email</span><p class="mt-0.5 text-gray-800">{{ request.user.email }}</p></div>
                <div class="bg-gray-50 rounded-lg p-3"><span class="text-xs text-gray-400 font-semibold">Telefoni</span><p class="mt-0.5 text-gray-800">{{ profile.phone or '-' }}</p></div>
            </div>
        </div>

        <div class="panel">
            <h2 class="text-base font-bold text-gray-800 mb-3">Porositë e fundit</h2>
            <div class="space-y-2">
                {% for order in recent_orders %}
                    <div class="flex items-center justify-between border border-gray-100 rounded-lg px-4 py-3 text-sm">
                        <div><p class="font-semibold text-gray-800">{{ order.order_number }}</p><p class="text-gray-400 text-xs">{{ order.status }}</p></div>
                        <span class="font-bold text-gray-700">{{ order.total_amount|money(order.currency) }}</span>
                    </div>
                {% else %}
                    <p class="text-sm text-gray-400">Nuk keni porosi ende.</p>
                {% endfor %}
            </div>
        </div>

        <div class="panel">
            <h2 class="text-base font-bold text-gray-800 mb-3">Të preferuarat</h2>
            <div class="grid gap-3 md:grid-cols-2">
                {% for item in wishlist_items %}
                    <a href="{{ url('catalog:product_detail', slug=item.product.slug) }}" class="border border-gray-100 rounded-lg p-3 text-sm hover:border-pink-300 transition">
                        <p class="font-semibold text-gray-800">{{ item.product.name }}</p>
                        <p class="text-pink-500 font-bold mt-1">{{ item.product.current_price|money }}</p>
                    </a>
                {% else %}
                    <p class="text-sm text-gray-400">Lista e dëshirave është bosh.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

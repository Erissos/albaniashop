{% extends 'layouts/base.jinja' %}

{% block title %}{{ form_title }} | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-lg">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900">{{ form_title }}</h1>
        <form method="post" class="mt-6 grid gap-4 md:grid-cols-2">
            {{ csrf_input }}
            {% for field in form %}
                <div class="{{ 'md:col-span-2' if field.name in ['address_line', 'address_line_2'] else '' }}">
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">{{ field.label }}</label>
                    {{ field }}
                    {% if field.errors %}<div class="mt-1 text-sm text-red-600">{{ field.errors }}</div>{% endif %}
                </div>
            {% endfor %}
            <div class="md:col-span-2 flex gap-3">
                <button type="submit" class="btn-pink btn-lg flex-1">Ruaj</button>
                <a href="{{ url('accounts:address_list') }}" class="btn-outline btn-lg flex-1 text-center">Anulo</a>
            </div>
        </form>
    </div>
</section>
{% endblock %}

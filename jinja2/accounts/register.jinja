{% extends 'layouts/base.jinja' %}

{% block title %}Regjistrohu | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-lg">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900 text-center">Krijo llogari</h1>
        <p class="text-sm text-gray-500 text-center mt-2">Regjistrohu për të përfituar nga ofertat dhe gjurmimi i porosive.</p>
        <form method="post" class="mt-6 grid gap-4 md:grid-cols-2">
            {{ csrf_input }}
            {% for field in form %}
                <div class="{{ 'md:col-span-2' if field.name in ['password1', 'password2'] else '' }}">
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">{{ field.label }}</label>
                    {{ field }}
                    {% if field.help_text %}<p class="mt-1 text-xs text-gray-400">{{ field.help_text }}</p>{% endif %}
                    {% if field.errors %}<div class="mt-1 text-sm text-red-600">{{ field.errors }}</div>{% endif %}
                </div>
            {% endfor %}
            <div class="md:col-span-2">
                <button type="submit" class="btn-pink btn-lg w-full">Regjistrohu</button>
            </div>
        </form>
        <p class="mt-4 text-sm text-gray-500 text-center">Ke tashmë llogari? <a href="{{ url('accounts:login') }}" class="text-pink-500 font-semibold hover:text-pink-600">Hyr</a></p>
    </div>
</section>
{% endblock %}

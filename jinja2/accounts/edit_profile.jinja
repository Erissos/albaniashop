{% extends 'layouts/base.jinja' %}

{% block title %}Ndrysho profilin | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-lg">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900">Ndrysho profilin</h1>
        <form method="post" class="mt-6 grid gap-4 md:grid-cols-2">
            {{ csrf_input }}
            {% for field in form %}
                <div class="{{ 'md:col-span-2' if field.name == 'phone' else '' }}">
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">{{ field.label }}</label>
                    {{ field }}
                    {% if field.errors %}<div class="mt-1 text-sm text-red-600">{{ field.errors }}</div>{% endif %}
                </div>
            {% endfor %}
            <div class="md:col-span-2"><button type="submit" class="btn-pink btn-lg w-full">Ruaj ndryshimet</button></div>
        </form>
    </div>
</section>
{% endblock %}

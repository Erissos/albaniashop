{% extends 'layouts/base.jinja' %}

{% block title %}Adresat | Albaniashop{% endblock %}

{% block content %}
<div class="flex items-center justify-between gap-4 mb-6">
    <h1 class="text-2xl font-extrabold text-gray-900">Adresat e ruajtura</h1>
    <a href="{{ url('accounts:address_create') }}" class="btn-pink">+ Shto adresë</a>
</div>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {% for address in addresses %}
        <div class="panel">
            <div class="flex items-center justify-between gap-2">
                <p class="font-bold text-gray-800">{{ address.title }}</p>
                {% if address.is_default %}<span class="badge badge-pink">Default</span>{% endif %}
            </div>
            <div class="mt-3 text-sm text-gray-600 space-y-0.5">
                <p>{{ address.full_name }}</p>
                <p>{{ address.address_line }}</p>
                {% if address.address_line_2 %}<p>{{ address.address_line_2 }}</p>{% endif %}
                <p>{{ address.city }}, {{ address.country }}</p>
            </div>
            <div class="mt-4 flex gap-2">
                <a href="{{ url('accounts:address_edit', pk=address.pk) }}" class="btn-outline btn-sm">Ndrysho</a>
                <a href="{{ url('accounts:address_delete', pk=address.pk) }}" class="btn-outline btn-sm text-red-500 border-red-200 hover:bg-red-50">Fshij</a>
            </div>
        </div>
    {% else %}
        <div class="panel text-gray-400 text-sm">Nuk keni adresa të ruajtura.</div>
    {% endfor %}
</div>
{% endblock %}

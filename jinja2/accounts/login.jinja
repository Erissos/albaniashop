{% extends 'layouts/base.jinja' %}

{% block title %}Hyr | Albaniashop{% endblock %}

{% block content %}
<section class="mx-auto max-w-md">
    <div class="panel">
        <h1 class="text-2xl font-extrabold text-gray-900 text-center">Hyr në llogarinë</h1>
        <p class="text-sm text-gray-500 text-center mt-2">Akseso porositë, listën e dëshirave dhe adresat tuaja.</p>
        <form method="post" class="mt-6 space-y-4">
            {{ csrf_input }}
            {% if form.non_field_errors() %}
                <div class="border border-red-200 bg-red-50 rounded-lg p-3 text-sm text-red-700">{{ form.non_field_errors() }}</div>
            {% endif %}
            {% for field in form %}
                <div>
                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 block">{{ field.label }}</label>
                    {{ field }}
                    {% if field.errors %}<div class="mt-1 text-sm text-red-600">{{ field.errors }}</div>{% endif %}
                </div>
            {% endfor %}
            <button type="submit" class="btn-pink btn-lg w-full">Hyr</button>
        </form>
        <p class="mt-4 text-sm text-gray-500 text-center">Nuk ke llogari? <a href="{{ url('accounts:register') }}" class="text-pink-500 font-semibold hover:text-pink-600">Regjistrohu</a></p>
    </div>
</section>
{% endblock %}

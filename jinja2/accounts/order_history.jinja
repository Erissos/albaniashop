{% extends 'layouts/base.jinja' %}

{% block title %}Porositë | Albaniashop{% endblock %}

{% block content %}
<h1 class="text-2xl font-extrabold text-gray-900 mb-6">Historiku i porosive</h1>
{% if orders %}
<div class="space-y-4">
    {% for order in orders %}
    <div class="panel">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
                <p class="font-bold text-gray-900">#{{ order.order_number }}</p>
                <p class="text-xs text-gray-400">{{ order.status }} • {{ order.payment_status }}</p>
            </div>
            <span class="font-bold text-gray-700">{{ order.total_amount|money(order.currency) }}</span>
        </div>
        <div class="mt-3 border-t border-gray-100 pt-3 space-y-2">
            {% for item in order.items.all() %}
            <div class="flex items-center justify-between text-sm">
                <span class="text-gray-700">{{ item.product.name if item.product else 'Produkt i fshirë' }} × {{ item.quantity }}</span>
                <span class="text-gray-500">{{ item.subtotal|money(order.currency) }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="panel text-center py-12">
    <svg class="w-12 h-12 text-gray-300 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/></svg>
    <p class="mt-4 text-gray-500">Nuk keni porosi ende.</p>
    <a href="{{ url('catalog:product_list') }}" class="btn-pink mt-4 inline-block">Shfleto produktet</a>
</div>
{% endif %}
{% endblock %}
